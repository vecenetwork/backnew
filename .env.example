# POSTGRES
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=test

# MINIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DEFAULT_BUCKET=vece
MINIO_REGION=eu-north-1
VIRTUAL_HOST=vece.localhost

# APPLICATION
# Google AI (Gemini) — для подсказки хештегов при создании вопроса (1–7 из списка)
GOOGLE_API_KEY=your-key-from-aistudio.google.com
# Resend (https://resend.com) — API key for sending emails
RESEND_API_KEY=re_xxxxxxxx
# From address (must be verified domain in Resend, e.g. info@vece.ai)
EMAIL_ADDRESS=info@vece.ai
ENVIRONMENT=local
# Supabase Storage для аватаров (profile-pictures bucket)
# Вариант 1: Supabase API (Settings → API)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Вариант 2: S3-совместимый API (Storage → S3 Configuration)
# SUPABASE_S3_ACCESS_KEY_ID=your-access-key-id
# SUPABASE_S3_SECRET_ACCESS_KEY=your-secret-access-key

SUPABASE_STORAGE_BUCKET=profile-pictures